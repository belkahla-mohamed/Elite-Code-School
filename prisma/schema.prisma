generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProgramLevel {
  debutant
  intermediaire
  avance

  @@map("program_level")
}

enum RequestStatus {
  pending
  accepted
  refused

  @@map("request_status")
}

enum ProjectStatus {
  completed
  in_progress

  @@map("project_status")
}

model Category {
  id          String    @id
  name        String
  slug        String    @unique
  description String    @default("")
  color       String    @default("sky")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")

  programs    Program[]

  @@map("categories")
}

model Program {
  id           String       @id
  title        String
  ageRange     String       @map("age_range")
  level        ProgramLevel
  description  String
  tools        String[]
  priceMonthly Int?         @map("price_monthly")
  color        String       @default("accent")
  image        String       @default("")
  duration     String       @default("")
  objectives   String       @default("")
  prerequisites String      @default("")
  schedule     String       @default("")
  sortOrder    Int          @default(0) @map("sort_order")
  createdAt    DateTime     @default(now()) @map("created_at")

  categoryId   String?      @map("category_id")
  category     Category?    @relation(fields: [categoryId], references: [id])

  students          Student[]
  inscriptionRequests InscriptionRequest[]

  @@map("programs")
}

model InscriptionRequest {
  id               String        @id @default(cuid())
  studentFirstName String        @map("student_first_name")
  studentLastName  String        @map("student_last_name")
  age              Int
  schoolLevel      String?       @map("school_level")
  programId        String        @map("program_id")
  program          Program       @relation(fields: [programId], references: [id])
  parentFirstName  String        @default("") @map("parent_first_name")
  parentLastName   String        @default("") @map("parent_last_name")
  parentPhone      String        @map("parent_phone")
  parentEmail      String        @map("parent_email")
  message          String?
  adminNotes       String?       @map("admin_notes")
  rejectionMessage String?       @map("rejection_message")
  status           RequestStatus @default(pending)
  createdAt        DateTime      @default(now()) @map("created_at")

  @@index([status])
  @@map("inscription_requests")
}

model Student {
  id               String   @id @default(cuid())
  slug             String   @unique
  firstName        String   @map("first_name")
  lastName         String   @map("last_name")
  age              Int
  avatar           String
  avatarGradient   String   @default("linear-gradient(135deg,#4f46e5,#06b6d4)") @map("avatar_gradient")
  programId        String   @map("program_id")
  program          Program  @relation(fields: [programId], references: [id])
  levelLabel       String   @map("level_label")
  joinDateLabel    String   @map("join_date_label")
  hours            Int      @default(0)
  isPublic         Boolean  @default(true) @map("is_public")
  parentEmail      String   @map("parent_email")
  parentSecretHash String   @map("parent_secret_hash")
  parentFirstName  String   @default("") @map("parent_first_name")
  parentLastName   String   @default("") @map("parent_last_name")
  createdAt        DateTime @default(now()) @map("created_at")

  projects       Project[]
  certifications Certification[]
  galleryItems   GalleryItem[]
  parents        Parent[] @ignore

  @@index([slug])
  @@index([isPublic])
  @@map("students")
}

model Project {
  id          String        @id @default(cuid())
  studentId   String        @map("student_id")
  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title       String
  description String
  tags        String[]
  status      ProjectStatus @default(in_progress)
  progress    Int           @default(0)
  dateLabel   String        @map("date_label")
  emoji       String        @default("💼")
  gradient    String        @default("linear-gradient(135deg,#4f46e5,#818cf8)")
  coverImage  String?       @map("cover_image")
  createdAt   DateTime      @default(now()) @map("created_at")

  @@index([studentId])
  @@map("projects")
}

model Certification {
  id         String   @id @default(cuid())
  studentId  String   @map("student_id")
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title      String
  mention    String   @default("Validé")
  dateLabel  String   @map("date_label")
  emoji      String   @default("🏅")
  gradient   String   @default("linear-gradient(135deg,#f59e0b,#f97316)")
  imageUrl   String?  @map("image_url")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([studentId])
  @@map("certifications")
}

model GalleryItem {
  id         String   @id @default(cuid())
  studentId  String   @map("student_id")
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  label      String
  emoji      String   @default("📸")
  gradient   String   @default("linear-gradient(135deg,#06b6d4,#0ea5e9)")
  imageUrl   String?  @map("image_url")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([studentId])
  @@map("gallery_items")
}

model AdminUser {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  role         String    @default("admin")
  passwordHash String    @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastLogin    DateTime? @map("last_login") @db.Timestamptz(6)

  @@map("admin_users")
  @@ignore
}

model Notification {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type        String
  title       String
  description String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("notifications")
  @@ignore
}

model Parent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String
  firstName  String   @map("first_name")
  lastName   String   @map("last_name")
  phone      String   @default("")
  secretHash String   @map("secret_hash")
  studentId  String   @map("student_id")
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("parents")
  @@ignore
}
